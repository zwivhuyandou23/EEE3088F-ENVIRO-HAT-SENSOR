  (text "CH340C" (at 31.6992 78.6384 0)
    (effects (font (size 3 3) (thickness 0.6) bold) (justify left bottom))
    (uuid 07e825f4-2bb2-4f24-87e5-06cabff30955)
  )
  (text "TEAM 26\nSIVUYILE NOSE\nMODULE INTERFACES WITH SENSOR AND POWER MODULES\nUCT\n"
    (at 178.2572 175.26 0)
    (effects (font (size 1.27 1.27) (color 140 0 0 1)) (justify left bottom))
    (uuid 14727329-5aa4-4adb-b912-009f5ea4e912)
  )
  (text "- Used to stored data collected from the sensing module\n- Pin 5(SCL2) and pin 6(SDA2) will connect to STM32F051C6\n- Pin 7(WC), will connect to MCU for prevention of write operations\n\n"
    (at 151.0792 86.2584 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 19087326-0639-4555-b4ff-3ac56f3bba3d)
  )
  (text "circuit is used to convert USB to UART via the TXD and RXD pins of the CH340C\nC10 actS as decoupling capacitors to filter out noise on the lines.\nAll unused pins are not connected. Test points to be added for debugging purposes\n"
    (at 53.2892 79.9084 0)
    (effects (font (face "KiCad Font") (size 1.5 1.5)) (justify left bottom))
    (uuid 89f7855c-6c41-4354-b6c6-4bbc62fbf8bf)
  )
  (text "EEPROM" (at 180.2892 77.3684 0)
    (effects (font (size 3 3) (thickness 0.6) bold) (justify left bottom))
    (uuid a14c02dc-beac-43f0-a3b7-dda0a3a88bb7)
  )
  (text "(USB TO UART)" (at 29.1592 82.4484 0)
    (effects (font (size 2 2) (thickness 0.4) bold) (justify left bottom))
    (uuid c82ecdf6-c163-41d7-8dda-e1b08bae770e)
